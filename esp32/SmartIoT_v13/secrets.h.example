/**********************************************************************************
 * secrets.h.example — SmartIoT v13 Firmware Secrets Template
 * ──────────────────────────────────────────────────────────────────────────────
 * HOW TO USE:
 *   1. Copy this file:  cp secrets.h.example secrets.h
 *   2. Fill in YOUR values below
 *   3. secrets.h is in .gitignore — NEVER commit the filled-in version
 *
 * ══════════════════════════════════════════════════════════════════════════════
 * SETUP STEPS (v13 — Firebase Custom Token Auth):
 * ══════════════════════════════════════════════════════════════════════════════
 *
 * STEP 1 — FIREBASE_HOST:
 *   Firebase Console → Realtime Database → Database URL
 *   Remove https:// and trailing /
 *   Example: yourproject-default-rtdb.firebaseio.com
 *
 * STEP 2 — FIREBASE_WEB_API_KEY:
 *   Firebase Console → Project Settings → General → Web API Key
 *   Example: AIzaSyAbc123XYZ...
 *
 * STEP 3 — DEVICE_REGISTRATION_SECRET:
 *   Generate a strong random key:
 *     openssl rand -hex 32
 *   Then set it in Firebase Cloud Functions:
 *     firebase functions:secrets:set DEVICE_REGISTRATION_SECRET
 *   Use the EXACT SAME value here.
 *
 * STEP 4 — CLOUD_FUNCTIONS_BASE_URL:
 *   Firebase Console → Functions → look at getDeviceToken URL
 *   Take only the base: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net
 *
 * STEP 5 — GOOGLE_ROOT_CA:
 *   The certificate below is correct (expires 2036). To renew:
 *     curl https://pki.goog/roots.pem
 *   Find the "GTS Root R1" entry.
 *
 **********************************************************************************/

#ifndef SECRETS_H
#define SECRETS_H

// ── Firebase Realtime Database Host ──────────────────────────────────────────
#define FIREBASE_HOST  "YOUR_PROJECT_ID-default-rtdb.firebaseio.com"

// ── Firebase Web API Key ──────────────────────────────────────────────────────
// Firebase Console → Project Settings → General → Web API Key
#define FIREBASE_WEB_API_KEY  "YOUR_FIREBASE_WEB_API_KEY_HERE"

// ── Device Registration Secret ────────────────────────────────────────────────
// Generate: openssl rand -hex 32
// Deploy:   firebase functions:secrets:set DEVICE_REGISTRATION_SECRET
#define DEVICE_REGISTRATION_SECRET  "YOUR_DEVICE_REGISTRATION_SECRET_HERE"

// ── Cloud Functions Base URL ──────────────────────────────────────────────────
#define CLOUD_FUNCTIONS_BASE_URL  "https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net"

// ── Google GTS Root R1 CA (for TLS) ──────────────────────────────────────────
